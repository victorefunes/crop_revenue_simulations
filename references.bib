}
@article{Ramirez2003,
author = {Ram\'{i}rez, Octavio A. and Fadiga, Mohamadou},
title = {Forecasting Agricultural Commodity Prices with Asymmetric-Error GARCH Models},
journal = {Journal of Agricultural and Resource Economics},
volume = {28},
number = {1},
pages = {71-85},
keywords = {GARCH, nonnormality, skewness,time-series forecasting, U.S. commodity prices},
doi = {},
